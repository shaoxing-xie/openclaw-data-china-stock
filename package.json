{
  "name": "@shaoxing-xie/openclaw-data-china-stock",
  "version": "0.5.11",
  "description": "A-share / ETF / option data for OpenClaw: unified market_data, P0/P1 tools, onshore fund flow (tool_fetch_a_share_fund_flow), technical screeners (tool_fetch_a_share_technical_screener), stock views, multi-source fallback.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    ".clawhubignore",
    "index.ts",
    "dist/index.js",
    "tool_runner.py",
    "config.yaml",
    "openclaw.plugin.json",
    "config/",
    "plugins/",
    "skills/",
    "src/",
    "README.md",
    "README_EN.md",
    "CHANGELOG.md",
    "SKILL.md",
    "package.json",
    "LICENSE"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": "*"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw/plugin-sdk",
    "prepack": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "devDependencies": {
    "esbuild": "^0.25.8"
  }
}
